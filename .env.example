APP_NAME=Akaunting
APP_ENV=production
APP_LOCALE=en-GB
APP_INSTALLED=false
APP_KEY=
APP_DEBUG=true
APP_SCHEDULE_TIME="09:00"
APP_URL=

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PREFIX=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

MAIL_MAILER=mail
MAIL_HOST=localhost
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_NAME=null
MAIL_FROM_ADDRESS=null

FIREWALL_ENABLED=false

MODEL_CACHE_ENABLED=false

DEBUGBAR_EDITOR=vscode
IGNITION_EDITOR=vscode

# ------------------------------------------------------------------------------
# OAuth2 / Passport
# Run: php artisan passport:keys  (generates storage/oauth-private.key, etc.)
# Run: php artisan passport:client --personal  (personal access client)
# Run: php artisan passport:client --password  (password grant client — optional)
# ------------------------------------------------------------------------------
OAUTH_ENABLED=false

# Inline encryption keys (alternative to key files on disk)
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# Personal Access Client — created by: php artisan passport:client --personal
OAUTH_PERSONAL_ACCESS_CLIENT_ID=
OAUTH_PERSONAL_ACCESS_CLIENT_SECRET=

# Password Grant Client — created by: php artisan passport:client --password
# DEPRECATED: Password Grant is deprecated in OAuth 2.1. Use Authorization Code + PKCE instead.
OAUTH_PASSWORD_GRANT_ENABLED=false
OAUTH_PASSWORD_GRANT_CLIENT_ID=
OAUTH_PASSWORD_GRANT_CLIENT_SECRET=

# Security
OAUTH_HASH_CLIENT_SECRETS=true
OAUTH_REQUIRE_PKCE=true
# Recommended: set to true in production to enforce RFC 8707 audience validation (prevents confused deputy attacks)
OAUTH_REQUIRE_AUDIENCE=false

# Dynamic Client Registration (RFC 7591) — enable for ChatGPT / Claude integrations
OAUTH_DCR_ENABLE_MANAGEMENT=false
